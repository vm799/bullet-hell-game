{
  "cli": {
    "version": ">= 11.0.0"
  },
  "build": {
    "development": {
      "distribution": "internal",
      "android": {
        "gradleCommand": ":app:assembleDebug"
      },
      "ios": {
        "buildConfiguration": "Debug"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "distribution": "store",
      "android": {
        "buildType": "aab"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "YOUR_APP_STORE_ID"
      },
      "android": {
        "serviceAccount": "YOUR_GOOGLE_SERVICE_ACCOUNT_JSON_PATH",
        "track": "production"
      }
    }
  }
}
